# Server Configuration
PORT=10000
NODE_ENV=production
JWT_SECRET=forgeengine_ultra_secure_2026_secret_key_!@#_FINAL

# Database Configuration
# Render-safe persistent path to the JSON database file
DB_PATH=/tmp/database.json

# Storage Configuration
# Render-safe persistent storage root
STORAGE_PATH=/tmp/storage
UPLOADS_PATH=/tmp/uploads
OUTPUTS_PATH=/tmp/outputs

# Integration Configuration
REDIS_URL=redis://127.0.0.1:6379
# Set to true to bypass all Redis attempts and use local polling/shims
DISABLE_REDIS=true
# Set to true to ensure all required directories are created on startup
AUTO_CREATE_DIR=true

# FFmpeg Configuration
FFMPEG_PATH=/usr/bin/ffmpeg

# Client/Frontend Configuration
VITE_API_URL=https://your-backend.onrender.com

# AI Service Configuration
GEMINI_API_KEY=
